{
  "name": "mr-luigi",
  "version": "1.0.0",
  "private": true,
  "description": "Mr. Luigi — Tienda gaming POS (Angular + Node.js)",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run start:local",
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "seed": "cd backend && npm run seed",
    "docker:rebuild": "powershell -ExecutionPolicy Bypass -File scripts/docker-rebuild.ps1",
    "sync:assets": "powershell -ExecutionPolicy Bypass -File scripts/sync-assets.ps1",
    "build:prod": "powershell -ExecutionPolicy Bypass -File scripts/build-prod.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
